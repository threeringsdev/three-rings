# Rust
/target/
**/*.rs.bk
# Cargo.lock is committed — this is an application (binary) workspace.

# Tauri
src-tauri/target/
# gen/android is committed (it carries the release cleartext/signing config;
# its own .gitignore excludes build outputs); schemas regenerate every build.
src-tauri/gen/schemas/
# Bundle resources the tauri CLI copies into the android project each build.
src-tauri/gen/android/app/src/main/assets/

# Frontend build output
/dist/

# App runtime state (e.g. the scaffold's file-backed counter)
/data/

# End-to-end tests (Playwright)
node_modules/
test-results/
end2end/playwright-report/
playwright/.cache/
# storageState from the login fixture (session cookies — never commit)
end2end/playwright/

# Environment / secrets
.env
.env.*
!.env.example

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp

# Claude Code — personal/local settings (shared config lives in .claude/settings.json)
.claude/settings.local.json
# Claude Code — local git worktrees for isolated agent runs (never committed)
.claude/worktrees/
