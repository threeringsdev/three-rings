{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": [
    "main"
  ],
  "permissions": [
    "core:default",
    "allow-open-url"
  ],
  "remote": {
    "urls": [
      "http://localhost:*",
      "http://127.0.0.1:*"
    ]
  },
  "local": true
}