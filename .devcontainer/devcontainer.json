{
  "name": "Three Rings",
  "image": "dgoings/three-rings:latest",
  "initializeCommand": "test -f .devcontainer/.env || cp .devcontainer/.env.example .devcontainer/.env",
  "runArgs": ["--env-file", "${localWorkspaceFolder}/.devcontainer/.env"],
  "mounts": [
    "source=${localWorkspaceFolder}/.devcontainer/.zshrc,target=/home/vscode/.zshrc,type=bind,consistency=cached",
    "source=three-rings-claude,target=/home/vscode/.claude,type=volume"
  ],
  "forwardPorts": [3000, 3001],
  "portsAttributes": {
    "3000": { "label": "Leptos app (SSR)" },
    "3001": { "label": "Leptos live-reload" }
  },
  "remoteUser": "vscode",
  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "tauri-apps.tauri-vscode",
        "bradlc.vscode-tailwindcss",
        "tamasfe.even-better-toml",
        "esbenp.prettier-vscode",
        "anthropic.claude-code",
        "augment.vscode-augment"
      ],
      "settings": {
        "editor.defaultFormatter": "esbenp.prettier-vscode",
        "[rust]": { "editor.defaultFormatter": "rust-lang.rust-analyzer" },
        "rust-analyzer.cargo.features": ["ssr"],
        "//": "src-tauri (three_rings) is the desktop target; it needs Tauri's Linux system libs (dbus/webkit2gtk) that this web-only container intentionally does not install (see specs/dev-environment.md). Excluding it keeps its unbuildable dep tree from crashing rust-analyzer's workspace check and flooding the Problems panel.",
        "rust-analyzer.cargo.buildScripts.overrideCommand": [
          "cargo", "check", "--quiet",
          "--workspace", "--exclude", "three_rings",
          "--all-targets", "--features", "ssr",
          "--message-format=json"
        ],
        "rust-analyzer.check.overrideCommand": [
          "cargo", "clippy",
          "--workspace", "--exclude", "three_rings",
          "--all-targets", "--features", "ssr",
          "--message-format=json"
        ]
      }
    }
  }
}
