# Copy to .devcontainer/.env (gitignored). `docker --env-file` reads it at container start.
# The devcontainer's initializeCommand auto-creates .env from this file if missing.

# --- Leptos ---
# Bind 0.0.0.0 so the forwarded port (3000) is reachable from the host browser.
LEPTOS_SITE_ADDR=0.0.0.0:3000
LEPTOS_RELOAD_PORT=3001

# --- Neon Postgres ---
# Never commit real values. All three point at the Neon DEV branch locally
# (Render sets the PRODUCTION values in its own env). Set the role passwords via
# each branch's Neon SQL Editor (`ALTER ROLE app_runtime PASSWORD '…'`), then
# paste them into the Console-shown connection strings.
#
# DATABASE_URL — the RUNTIME connection the web server uses: the non-owner
# `app_runtime` role (RLS-subject, no DDL). This is what `cargo leptos watch` runs as.
# DATABASE_URL=postgres://app_runtime:PASSWORD@ep-xxxx.REGION.aws.neon.tech/neondb?sslmode=require
#
# MIGRATION_DATABASE_URL — the OWNER role (needs DDL), used ONLY by
# `scripts/migrate.sh` / `server --migrate` to apply migrations to the DEV branch.
# The app never uses it. (`--migrate` falls back to DATABASE_URL if this is unset.)
# MIGRATION_DATABASE_URL=postgres://neondb_owner:PASSWORD@ep-xxxx.REGION.aws.neon.tech/neondb?sslmode=require
#
# PROD_MIGRATION_DATABASE_URL — the PRODUCTION branch OWNER string, used ONLY by
# `scripts/migrate.sh prod` to migrate production from this trusted machine
# (Option B: migrations never run from Render's free tier or CI). Owner cred —
# keep it here (gitignored) and nowhere else.
# PROD_MIGRATION_DATABASE_URL=postgres://neondb_owner:PASSWORD@ep-curly-pond-atsb6fgp.c-9.us-east-1.aws.neon.tech/neondb?sslmode=require

# --- Neon Auth (Better Auth; already provisioned per Neon branch) ---
# Non-secret, branch-specific. This is the DEV branch's auth service (local dev uses
# the Neon dev branch); Render sets the PRODUCTION branch's URL in its own env.
# base_url origin = the JWT issuer/audience; the JWKS the API verifies against is
# <base_url>/.well-known/jwks.json. Required by the cookie-session proxy (app/src/auth/)
# — sign-in/up, OTP verify, and Google all 500 without it. Render carries the
# production branch's URL in its own env.
NEON_AUTH_BASE_URL=https://ep-dry-cell-atj9rpc2.neonauth.c-9.us-east-1.aws.neon.tech/neondb/auth

# --- Claude Code auth (skip in-container login) ---
# Container ~/.claude/.credentials.json is lost on rebuild, so `claude` re-asks.
# Generate a long-lived token on the host with `claude setup-token` (Pro/Max)
# and set it here; claude picks it up and skips login. Treat like a password.
# CLAUDE_CODE_OAUTH_TOKEN=sk-ant-oat01-...

# --- GitHub auth (see README.md "Git / GitHub auth") ---
# GH_TOKEN=ghp_...
